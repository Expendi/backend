DATABASE_URL=postgresql://user:password@localhost:5432/expendi
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key
ADMIN_API_KEY=your-admin-api-key
DEFAULT_CHAIN_ID=1
PORT=3000
PRETIUM_API_KEY=your-pretium-api-key
PRETIUM_BASE_URI=https://api.xwift.africa

# Uniswap Trading API -- token swaps on Base
# Get your API key from https://developers.uniswap.org/
UNISWAP_API_KEY=your-uniswap-api-key

# WebAuthn -- passkey origins (comma-separated for multiple)
# WEBAUTHN_ORIGINS=https://expendi.app,android:apk-key-hash:<base64url-SHA256-of-signing-cert>
# Or use WEBAUTHN_ORIGIN for a single origin (fallback if WEBAUTHN_ORIGINS is not set)
# WEBAUTHN_ORIGIN=https://expendi.app

# Trigger.dev -- scheduled task execution
# Get these from your Trigger.dev dashboard (https://trigger.dev)
TRIGGER_SECRET_KEY=tr_dev_your-trigger-secret-key
TRIGGER_PROJECT_REF=your-trigger-project-ref
