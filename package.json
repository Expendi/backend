{
  "name": "expendi-backend",
  "version": "1.0.0",
  "description": "Expendi - Crypto financial backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "db:generate": "node --import tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --import tsx node_modules/drizzle-kit/bin.cjs migrate",
    "test": "vitest run",
    "trigger:dev": "npx trigger.dev@latest dev",
    "trigger:deploy": "npx trigger.dev@latest deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@trigger.dev/build": "4.4.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@privy-io/node": "^0.9.0",
    "@simplewebauthn/server": "^13.3.0",
    "@trigger.dev/sdk": "4.4.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.19.18",
    "hono": "^4.7.12",
    "pg": "^8.18.0",
    "viem": "^2.31.3",
    "zod": "^4.3.6"
  }
}