		{
			"name": "Public API",
			"item": [
				{
					"name": "Onboarding",
					"item": [
						{
							"name": "Onboard User",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									},
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"chainId\": 1\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/api/onboard",
									"host": ["{{baseUrl}}"],
									"path": ["api", "onboard"]
								},
								"description": "Onboards the authenticated user by creating three wallets (user, server, agent) and a user_profiles record linking them. This operation is idempotent -- calling it again for an already-onboarded user returns the existing profile and wallets without creating duplicates. The chainId defaults to 1 (Ethereum Mainnet) if not specified."
							},
							"response": []
						},
						{
							"name": "Get My Profile",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									}
								],
								"url": {
									"raw": "{{baseUrl}}/api/profile",
									"host": ["{{baseUrl}}"],
									"path": ["api", "profile"]
								},
								"description": "Retrieves the authenticated user's onboarding profile with all wallet details populated (user, server, agent wallets). Returns 400 with OnboardingError if the user has not been onboarded yet."
							},
							"response": []
						},
						{
							"name": "Get My Wallet Addresses",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									}
								],
								"url": {
									"raw": "{{baseUrl}}/api/profile/wallets",
									"host": ["{{baseUrl}}"],
									"path": ["api", "profile", "wallets"]
								},
								"description": "Returns just the wallet addresses for the authenticated user, keyed by type: { user: '0x...', server: '0x...', agent: '0x...' }. A convenience endpoint for clients that only need addresses. Returns 400 with OnboardingError if the user has not been onboarded."
							},
							"response": []
						}
					],
					"description": "User onboarding and profile endpoints. Requires Privy auth. Creates a complete wallet set (user, server, agent) and a profile record linking them. The onboard operation is idempotent."
				},
				{
					"name": "Wallets",
					"item": [
						{
							"name": "List My Wallets",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									}
								],
								"url": {
									"raw": "{{baseUrl}}/api/wallets",
									"host": ["{{baseUrl}}"],
									"path": ["api", "wallets"]
								},
								"description": "Retrieves the authenticated user's own wallets, ordered by creation date. Only wallets where ownerId matches the authenticated user's Privy DID are returned."
							},
							"response": []
						},
						{
							"name": "Get Wallet by ID",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									}
								],
								"url": {
									"raw": "{{baseUrl}}/api/wallets/{{walletId}}",
									"host": ["{{baseUrl}}"],
									"path": ["api", "wallets", "{{walletId}}"]
								},
								"description": "Retrieves a single wallet by its UUID. Returns 400 if the wallet is not found or not owned by the authenticated user."
							},
							"response": []
						},
						{
							"name": "Create User Wallet",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									},
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{}"
								},
								"url": {
									"raw": "{{baseUrl}}/api/wallets/user",
									"host": ["{{baseUrl}}"],
									"path": ["api", "wallets", "user"]
								},
								"description": "Creates a new user-type wallet via Privy. The userId is automatically extracted from the authenticated Privy token -- no userId in the request body is needed. Returns the new wallet address and type."
							},
							"response": []
						},
						{
							"name": "Sign Message",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									},
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"message\": \"Please sign this message to verify ownership of wallet 0x742d35Cc6634C0532925a3b844Bc9e7595f2bD68. Nonce: 8a4f2b1c\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/api/wallets/{{walletId}}/sign",
									"host": ["{{baseUrl}}"],
									"path": ["api", "wallets", "{{walletId}}", "sign"]
								},
								"description": "Signs an arbitrary message using the wallet's private key resolved through Privy. The authenticated user must own the wallet. Returns the hex-encoded signature."
							},
							"response": []
						}
					],
					"description": "Public wallet endpoints. Requires Privy auth. Users can only access their own wallets. User wallet creation uses the userId from the auth context."
				},
