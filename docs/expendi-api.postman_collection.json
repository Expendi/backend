								"url": {
									"raw": "{{baseUrl}}/api/transactions/contract",
									"host": ["{{baseUrl}}"],
									"path": ["api", "transactions", "contract"]
								},
								"description": "Submits a transaction that calls a method on a registered contract, identifying the wallet by its database UUID. The authenticated user must own the specified wallet. The userId is set automatically from the auth context."
							},
							"response": []
						},
						{
