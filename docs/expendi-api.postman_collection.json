									"host": ["{{baseUrl}}"],
									"path": ["api", "transactions", "raw"]
								},
								"description": "Submits a raw Ethereum transaction with pre-encoded calldata, identifying the wallet by its database UUID. The authenticated user must own the specified wallet. The userId is set automatically from the auth context."
							},
							"response": []
						},
						{
							"name": "Submit Raw Transaction (by walletType)",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{authToken}}"
									},
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"walletType\": \"user\",\n  \"chainId\": 1,\n  \"to\": \"0x742d35Cc6634C0532925a3b844Bc9e7595f2bD68\",\n  \"value\": \"1000000000000000000\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/api/transactions/raw",
									"host": ["{{baseUrl}}"],
									"path": ["api", "transactions", "raw"]
								},
								"description": "Submits a raw Ethereum transaction using walletType instead of walletId. The wallet is resolved from the user's onboarding profile (user_profiles table). The user must be onboarded first via POST /api/onboard. Valid walletType values: 'user', 'server', 'agent'."
							},
							"response": []
						}
					],
					"description": "Public transaction endpoints. Requires Privy auth. Users can only view their own transactions and must own the wallet used for submissions. Wallets can be identified by walletId (database UUID) or walletType (resolved from the user's onboarding profile)."
				},
