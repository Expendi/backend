								"body": {
									"mode": "raw",
									"raw": "{\n  \"walletType\": \"server\",\n  \"contractName\": \"usdc\",\n  \"chainId\": 1,\n  \"method\": \"transfer\",\n  \"args\": [\n    \"0xdAC17F958D2ee523a2206206994597C13D831ec7\",\n    \"1000000\"\n  ]\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/api/transactions/contract",
									"host": ["{{baseUrl}}"],
									"path": ["api", "transactions", "contract"]
								},
								"description": "Submits a contract transaction using walletType instead of walletId. The wallet is resolved from the user's onboarding profile (user_profiles table). The user must be onboarded first via POST /api/onboard. Valid walletType values: 'user', 'server', 'agent'."
							},
							"response": []
						},
